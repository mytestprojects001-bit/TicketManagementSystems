{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=TicketManagement;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECRET_KEY_SHOULD_BE_LONG",
    "Issuer": "TicketManagementAPI",
    "Audience": "TicketManagementClients",
    "ExpireMinutes": 60,
    "RefreshTokenExpireDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": "Information"
  }
}
